GROQ_API_KEY=
OPENAI_API_KEY=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
NAUKRI_HEADLESS=false

# LLM provider selection — supported values: groq, openai
# Set PRIMARY to the provider you want used first.
# Set FALLBACK to the provider used when primary hits rate limits (optional).
# If MODEL vars are omitted, defaults are: groq → llama-3.3-70b-versatile, openai → gpt-4o
LLM_PRIMARY_PROVIDER=groq
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o
